{
  "configVersion": "v3",
  "app": {
    "appId": 1120339,
    "appName": "Z-Tally",
    "appType": "app",
    "version": {
      "code": 2,
      "name": "1.1.0"
    },
    "icon": "icon.png",
    "vender": "Regulus",
    "description": "A multi-counter tally app for round and square Amazfit watches"
  },
  "permissions": [
    "device:os.local_storage"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0.0",
      "target": "3.0.0",
      "minVersion": "3.0"
    }
  },
  "debug": false,
  "targets": {
    "round": {
      "module": {
        "page": {
          "pages": [
            "page/round/home/index.page",
            "page/round/tutorial/index.page",
            "page/round/history/index.page",
            "page/round/settings/index.page",
            "page/round/screen-timeout/index.page",
            "page/round/about/index.page"
          ]
        },
        "secondary-widget": {
          "widgets": [
            {
              "path": "secondary-widget/index",
              "icon": "icon.png",
              "preview": "widget-preview.png",
              "name": "Z-Tally",
              "runtime": {
                "type": "js"
              },
              "i18n": {
                "en-US": {
                  "name": "Z-Tally"
                },
                "zh-CN": {
                  "name": "Z-Tally 计数"
                }
              }
            }
          ]
        }
      },
      "platforms": [
        {
          "st": "r"
        }
      ],
      "designWidth": 480
    },
    "square": {
      "module": {
        "page": {
          "pages": [
            "page/square/home/index.page",
            "page/square/tutorial/index.page",
            "page/square/history/index.page",
            "page/square/settings/index.page",
            "page/square/screen-timeout/index.page",
            "page/square/about/index.page"
          ]
        },
        "secondary-widget": {
          "widgets": [
            {
              "path": "secondary-widget/index",
              "icon": "icon.png",
              "preview": "widget-preview.png",
              "name": "Z-Tally",
              "runtime": {
                "type": "js"
              },
              "i18n": {
                "en-US": {
                  "name": "Z-Tally"
                },
                "zh-CN": {
                  "name": "Z-Tally 计数"
                }
              }
            }
          ]
        }
      },
      "platforms": [
        {
          "st": "s",
          "sr": "w390"
        }
      ],
      "designWidth": 390
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Z-Tally"
    },
    "zh-CN": {
      "appName": "Z-Tally"
    }
  },
  "defaultLanguage": "en-US"
}
